# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Webhook secret — from Stripe dashboard → Webhooks → your endpoint
# For local dev: stripe listen --forward-to localhost:3000/api/stripe/webhooks
STRIPE_WEBHOOK_SECRET=whsec_

# Your price IDs from Stripe dashboard → Products
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_
NEXT_PUBLIC_STRIPE_PRICE_YEARLY=price_

# ── Stripe Connect (set by Vibe Launchpad when provisioned via platform) ────
# Leave blank if running standalone with your own Stripe account
STRIPE_CONNECT_ACCOUNT_ID=
STRIPE_PLATFORM_FEE_PERCENT=

# ── App URL (used for redirect URLs) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Market data ─────────────────────────────────────────────────────────────
# FMP (fundamentals): https://financialmodelingprep.com/ — uses the `stable` API base.
FMP_API_KEY=
# Twelve Data (4-hour candles): free key from https://twelvedata.com/ — supports interval=4h.
TWELVEDATA_API_KEY=

# ── Alerts ──────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_
ALERT_RECIPIENT_EMAIL=

# ── Cron auth ───────────────────────────────────────────────────────────────
# Shared secret; the scan endpoint requires `Authorization: Bearer <CRON_SECRET>`.
# Set the same value in Vercel env, and as the CRON_SECRET GitHub repo secret.
CRON_SECRET=
